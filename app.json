{
  "expo": {
    "name": "MindMate",
    "slug": "mindmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mindmate",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#060810"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mindmate.app"
    },
    "android": {
      "package": "com.mindmate.app",
      "adaptiveIcon": { "backgroundColor": "#060810" },
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
