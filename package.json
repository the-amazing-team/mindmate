{
  "name": "mindmate",
  "version": "1.0.0",
  "main": "expo/AppEntry",
  "scripts": {
    "start": "npx expo start",
    "android": "adb reverse tcp:3000 tcp:3000 && npx expo run:android",
    "web": "npx expo start --web",
    "api": "npm run start:dev --prefix api",
    "dev:web": "concurrently \"npm run web\" \"npm run api\"",
    "dev:android": "adb reverse tcp:3000 tcp:3000 && concurrently \"npx expo run:android\" \"npm run api\""
  },
  "dependencies": {
    "expo": "~52.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.2",
    "react-native": "0.76.3",
    "react-dom": "18.3.2",
    "@expo/metro-runtime": "~4.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.3.12",
    "concurrently": "^9.0.0",
    "typescript": "~5.3.3"
  }
}
