# =============================================
# MindMate API - Environment Variables Example
# =============================================
# Copy this file to .env and fill in your values

# ------------------------------------------
# Database (Supabase PostgreSQL)
# ------------------------------------------
# Connection string with PgBouncer (connection pooling) - used at runtime
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[YOUR-REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection string - used for Prisma migrations
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[YOUR-REGION].pooler.supabase.com:5432/postgres"

# ------------------------------------------
# Supabase Configuration
# ------------------------------------------
# Project URL (found in Supabase dashboard > Project Settings > API)
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"

# Anon/public key (safe to expose in browser)
SUPABASE_ANON_KEY="your-anon-key"

# Service role key (keep this secret! Never expose in browser)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ------------------------------------------
# Application
# ------------------------------------------
PORT=3000

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS="http://localhost:8081,http://localhost:19006"
