// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String           @id @default(cuid())
  email               String           @unique
  password_hash       String
  name                String?
  auth_type           AuthType         @default(EMAIL)
  age_group           String?
  personality_type    PersonalityType?
  goals               String[]         @default([])
  reminders           String?
  notifications_enabled    Boolean          @default(true)
  reminders_enabled        Boolean          @default(true)
  weekly_insights_enabled  Boolean          @default(true)
  marketing_emails_enabled Boolean          @default(false)
  onboarding_complete Boolean          @default(false)
  is_verified         Boolean          @default(false)
  installations       Installation[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  journal_entries     JournalEntry[]
  insights            Insight[]
  check_ins           CheckIn[]
}

model CheckIn {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  mood_score Int
  note       String?
  created_at DateTime @default(now())

  @@index([user_id])
}

model JournalEntry {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String
  user         User             @relation(fields: [user_id], references: [id])
  title        String?
  overall_mood String
  sections     JournalSection[]
  insights     Insight[]
  created_at   DateTime         @default(now())
  updated_at   DateTime         @updatedAt

  @@index([user_id])
}

model JournalSection {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  journal_entry_id String       @db.Uuid
  journal_entry    JournalEntry @relation(fields: [journal_entry_id], references: [id], onDelete: Cascade)
  content          String       @db.Text
  section_order    Int
  primary_emotion  String?
  emotion_score    Float?
  reflection_text  String?
  created_at       DateTime     @default(now())

  @@index([journal_entry_id])
}

model Insight {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String
  user             User          @relation(fields: [user_id], references: [id])
  journal_entry_id String?       @db.Uuid
  journal_entry    JournalEntry? @relation(fields: [journal_entry_id], references: [id], onDelete: SetNull)
  summary          String        @db.Text
  recommendation   String        @db.Text
  patterns         Json?
  created_at       DateTime      @default(now())

  @@index([user_id])
  @@index([journal_entry_id])
}

model Plugin {
  id            String         @id @default(cuid())
  name          String
  description   String
  icon          String
  author        String
  category      String
  price         Float          @default(0)
  rating        Float          @default(0)
  reviews       Int            @default(0)
  installs      String         @default("0")
  code          String         // The executable JS code
  verified      Boolean        @default(false)
  installations Installation[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Installation {
  id        String   @id @default(cuid())
  userId    String
  pluginId  String
  user      User     @relation(fields: [userId], references: [id])
  plugin    Plugin   @relation(fields: [pluginId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, pluginId])
}

model Otp {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String
  otp       String
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([email])
}

enum AuthType {
  GOOGLE
  EMAIL
}

enum PersonalityType {
  INTROVERT
  EXTROVERT
  AMBIVERT
}
